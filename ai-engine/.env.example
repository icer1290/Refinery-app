# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/news_aggregator

# LangSmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT="Refinery-app"

# LLM API Configuration (Alibaba DashScope / OpenAI compatible)
# OPENAI_API_KEY=sk-sp-d69895422cc14b6893c044908558f9b0
OPENAI_API_KEY=your_openai_api_key

# OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Models (DashScope compatible models)
OPENAI_EMBEDDING_MODEL=text-embedding-v4
OPENAI_CHAT_MODEL=qwen3.5-35b-a3b

# Deduplication
DEDUP_SIMILARITY_THRESHOLD=0.85

# Scoring
SCORE_THRESHOLD=5.0

# Reflection
MAX_REFLECTION_RETRIES=7

# Concurrency
MAX_CONCURRENT_SCORERS=5
MAX_CONCURRENT_WRITERS=3

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true